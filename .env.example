# Wekams Lens — environment configuration
# Copy this file to `.env` and fill in values. Never commit `.env`.

# ─── App ─────────────────────────────────────────────────────────────
WEKAMS_ENV=development            # development | production
WEKAMS_LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
WEKAMS_HOST=0.0.0.0
WEKAMS_PORT=8000

# ─── LLM ─────────────────────────────────────────────────────────────
# Pluggable backend. Use `ollama` for offline / air-gapped deployments.
# Use `groq` for fast cloud dev (free tier at https://console.groq.com).
WEKAMS_LLM_PROVIDER=ollama        # ollama | groq

# Groq (dev only — bring your own free API key)
GROQ_API_KEY=
WEKAMS_LLM_MODEL_GROQ=qwen/qwen3-32b

# Ollama (local, offline-capable — production default)
OLLAMA_HOST=http://localhost:11434
WEKAMS_LLM_MODEL_OLLAMA=qwen2.5:7b-instruct  # for 8GB Macs use qwen2.5:3b

# ─── Catalog DB ──────────────────────────────────────────────────────
# Stores registered sources, conversations, and chat messages.
# Bundled Postgres via docker-compose in dev. Bring your own for production.
WEKAMS_CATALOG_DB_URL=postgresql+asyncpg://wekams:wekams_dev@localhost:5433/wekams_catalog

# ─── Demo source (optional) ──────────────────────────────────────────
# Sample Postgres with e-commerce seed data — register it via the UI to
# try a natural-language query against a working source.
DEMO_SOURCE_HOST=localhost
DEMO_SOURCE_PORT=5434
DEMO_SOURCE_DB=shop
DEMO_SOURCE_USER=demo
DEMO_SOURCE_PASSWORD=demo_pw

# ─── Frontend ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE=http://localhost:8000
